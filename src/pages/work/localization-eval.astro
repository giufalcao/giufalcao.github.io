---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

const mermaidDiagram = `flowchart LR
    BQ[(BigQuery\\ntranscripts)]:::storage
    BASE[Baseline run\\nEnglish dims]:::run
    TEST[Test run\\ntarget-lang dims\\nx3 for noise floor]:::run
    LF[(Langfuse\\ntraces)]:::storage

    OL{output-language\\nprerequisite}:::prereq
    SC[score-consistency]:::judge
    DA[dimension-alignment]:::judge
    FQ[feedback-quality]:::judge
    CN[coaching-naturalness]:::judge
    HC[Human calibration\\nbilingual experts]:::human
    GATE{Release gate\\n>=80% agreement}:::gate
    PASS[Approved]:::pass
    FAIL[Blocked]:::fail

    BQ --> BASE & TEST --> LF
    LF --> OL
    OL -->|fails| FAIL
    OL -->|passes| SC --> DA --> FQ --> CN --> HC --> GATE
    GATE -->|meets threshold| PASS
    GATE -->|below threshold| FAIL

    classDef storage fill:#f1f5f9,stroke:#cbd5e1,color:#475569
    classDef run fill:#1e3a5f,stroke:#3b82f6,color:#93c5fd
    classDef prereq fill:#3b0a0a,stroke:#ef4444,color:#fca5a5
    classDef judge fill:#f1f5f9,stroke:#94a3b8,color:#475569
    classDef human fill:#2d1b4e,stroke:#8b5cf6,color:#c4b5fd
    classDef gate fill:#1a1f0a,stroke:#84cc16,color:#86efac
    classDef pass fill:#1a2f1a,stroke:#10b981,color:#6ee7b7
    classDef fail fill:#1e293b,stroke:#334155,color:#64748b`;
---

<CaseStudyLayout
  title="Localization Quality Framework"
  description="Building a reliable gate for LLM evaluation quality across languages."
  accent="#14b8a6"
  codeColor="#0f766e"
  mermaidPrimary="#ccfbf1"
  mermaidPrimaryText="#134e4a"
  mermaidPrimaryBorder="#5eead4"
>

