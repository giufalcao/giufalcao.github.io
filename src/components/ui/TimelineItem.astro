---
import type { ExperienceEntry } from '../../data/experience';

interface Props {
  entry: ExperienceEntry;
  isLast?: boolean;
}

const { entry, isLast = false } = Astro.props;
---

<div class="relative pl-8">
  <!-- Timeline dot and line -->
  <div class="absolute left-0 top-1.5 w-3 h-3 rounded-full bg-accent border-2 border-bg z-10"></div>
  {!isLast && (
    <div class="absolute left-1.5 top-4 bottom-0 w-px bg-gradient-to-b from-accent-border to-transparent"></div>
  )}

  <!-- Content -->
  <div class="pb-12">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
      <div>
        <span class="font-bold text-text-primary text-lg">{entry.role}</span>
        <span class="text-text-secondary mx-2">@</span>
        <span class="text-accent font-semibold">{entry.company}</span>
      </div>
      <span class="text-sm text-text-muted font-mono shrink-0">{entry.period}</span>
    </div>
    <div class="text-sm text-text-muted mb-4 font-mono">{entry.location}</div>

    <!-- Bullets -->
    <ul class="space-y-3">
      {entry.bullets.map((bullet) => (
        <li class="flex gap-3 text-text-secondary leading-relaxed">
          <span class="text-accent mt-1.5 shrink-0 text-xs">▸</span>
          <span>
            {bullet.metrics ? (
              <>
                {bullet.text.split(bullet.metrics[0]?.value ?? '')[0]}
                {bullet.metrics.map((m) => (
                  <><span class="text-metric font-semibold font-mono">{m.value}</span>{m.label && <span class="text-text-muted text-xs ml-1">({m.label})</span>}</>
                ))}
              </>
            ) : (
              bullet.text
            )}
          </span>
        </li>
      ))}
    </ul>

    {entry.note && (
      <p class="mt-4 text-sm text-text-muted italic border-l-2 border-border pl-3">
        {entry.note}
      </p>
    )}
  </div>
</div>
