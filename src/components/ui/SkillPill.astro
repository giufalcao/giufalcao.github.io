---
import type { SkillTier } from '../../data/skills';

interface Props {
  name: string;
  tier?: SkillTier;
  colorScheme?: 'emerald' | 'blue' | 'slate' | 'muted' | 'purple';
}

const { name, tier = 'proficient', colorScheme = 'muted' } = Astro.props;

const schemeClasses: Record<string, string> = {
  emerald: 'bg-accent-subtle border-accent-border text-accent',
  blue: 'bg-blue-950/50 border-blue-800/40 text-blue-300',
  slate: 'bg-slate-800/50 border-slate-700/40 text-slate-300',
  muted: 'bg-surface-2 border-border text-text-secondary',
  purple: 'bg-purple-950/50 border-purple-800/40 text-purple-300',
};

const classes = tier === 'core'
  ? schemeClasses[colorScheme]
  : 'bg-surface-2 border-border text-text-muted';
---

<span class:list={['tech-pill', classes, 'text-xs font-mono px-3 py-1 rounded-full border transition-colors duration-200']}>
  {name}
  {tier === 'core' && <span class="ml-1 w-1.5 h-1.5 rounded-full bg-current opacity-60 inline-block"></span>}
</span>
