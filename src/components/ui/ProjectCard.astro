---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const accentClasses: Record<string, { bar: string; badge: string; link: string }> = {
  emerald: {
    bar: 'from-accent to-accent-dim',
    badge: 'bg-accent-subtle border-accent-border text-accent',
    link: 'text-accent hover:text-accent-dim',
  },
  blue: {
    bar: 'from-blue-500 to-blue-700',
    badge: 'bg-blue-950/50 border-blue-800/40 text-blue-300',
    link: 'text-blue-400 hover:text-blue-300',
  },
  teal: {
    bar: 'from-teal-500 to-teal-700',
    badge: 'bg-teal-950/50 border-teal-800/40 text-teal-300',
    link: 'text-teal-400 hover:text-teal-300',
  },
};

const accent = accentClasses[project.accentColor];
---

<article class="card group flex flex-col h-full">
  <!-- Top accent bar -->
  <div class:list={['h-0.5 -mx-6 -mt-6 mb-6 rounded-t-xl bg-gradient-to-r', accent.bar]}></div>

  <!-- Categories -->
  <div class="flex flex-wrap gap-2 mb-4">
    {project.categories.map((cat) => (
      <span class:list={['badge border text-xs', accent.badge]}>{cat}</span>
    ))}
  </div>

  <!-- Title -->
  <h3 class="text-xl font-bold text-text-primary mb-3 group-hover:text-text-primary transition-colors">
    {project.title}
  </h3>

  <!-- Description -->
  <p class="text-text-secondary text-sm leading-relaxed mb-4 flex-grow">
    {project.description}
  </p>

  <!-- Motivation quote (Voto Explicado) -->
  {project.motivation && (
    <blockquote class="text-sm text-text-muted italic border-l-2 border-border pl-3 mb-4">
      "{project.motivation}"
    </blockquote>
  )}

  <!-- Pipeline label -->
  {project.pipelineLabel && (
    <div class="text-xs font-mono text-text-muted bg-surface-2 border border-border rounded-md px-3 py-2 mb-4 overflow-x-auto whitespace-nowrap">
      {project.pipelineLabel}
    </div>
  )}

  <!-- Tech stack -->
  <div class="flex flex-wrap gap-2 mb-6">
    {project.techStack.map((tech) => (
      <span class="tech-pill">{tech}</span>
    ))}
  </div>

  <!-- Footer links -->
  <div class="flex items-center justify-between mt-auto pt-4 border-t border-border">
    {project.repo && (
      <a
        href={project.repo}
        target="_blank"
        rel="noopener noreferrer"
        class:list={['inline-flex items-center gap-2 text-sm font-medium transition-colors', accent.link]}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    )}

    {project.demo && (
      <a
        href={project.demo}
        target="_blank"
        rel="noopener noreferrer"
        class:list={['inline-flex items-center gap-2 text-sm font-medium transition-colors', accent.link]}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        Live Demo
      </a>
    )}

    {project.isPrivate && (
      <span class="text-xs text-text-muted font-mono">
        Private repo — by design
      </span>
    )}
  </div>
</article>
