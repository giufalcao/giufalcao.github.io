---
interface Props {
  title: string;
  subtitle?: string;
  id: string;
  centered?: boolean;
}

const { title, subtitle, id, centered = false } = Astro.props;
---

<div id={id} class:list={['mb-10 scroll-mt-24', centered && 'text-center']}>
  <div class:list={['flex items-center gap-4 mb-4', centered && 'justify-center']}>
    <span class="h-px w-12 bg-accent/60 hidden sm:block"></span>
    <h2 class="text-3xl font-bold text-text-primary">{title}</h2>
  </div>
  {subtitle && (
    <p class="text-text-secondary text-lg max-w-2xl" class:list={[centered && 'mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
