---
import SectionHeader from '../ui/SectionHeader.astro';
import SkillPill from '../ui/SkillPill.astro';
import { skillGroups } from '../../data/skills';
---

<section class="section-padding">
  <div class="max-w-6xl mx-auto">
    <SectionHeader
      id="skills"
      title="Skills & Tools"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {skillGroups.map((group) => (
        <div class="card">
          <h3 class="text-sm font-semibold text-text-secondary uppercase tracking-wider font-mono mb-4">
            {group.label}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <SkillPill name={skill.name} tier={skill.tier} years={skill.years} colorScheme={group.colorScheme} />
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="text-xs text-text-muted font-mono mt-6 text-center">
      years of experience shown per skill
    </p>
  </div>
</section>
