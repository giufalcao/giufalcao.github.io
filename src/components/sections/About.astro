---
import SectionHeader from '../ui/SectionHeader.astro';
import { certifications, publications } from '../../data/certifications';
---

<section class="section-padding">
  <div class="max-w-6xl mx-auto">
    <SectionHeader id="about" title="About" />

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Left: Story (2 columns wide) -->
      <div class="lg:col-span-2 space-y-6">
        <p class="text-text-primary text-lg leading-relaxed">
          I started building software systems. Then I learned how they break with data.
          Now I build the infrastructure that keeps AI systems reliable in production.
        </p>

        <p class="text-text-secondary leading-relaxed">
          Over 6+ years spanning software engineering, data science, and ML engineering,
          I've shipped recommendation systems that cut costs by 60%, LLM evaluation pipelines
          running at scale on GCP, and civic tech applications that make government data
          accessible to everyone. I care about systems that are measurably better — not just
          working, but optimal.
        </p>

        <p class="text-text-secondary leading-relaxed">
          My trajectory from Software Engineer → Data Scientist → ML Engineer gives me an
          unusual perspective: I understand how production systems fail, how data quality
          breaks models, and how infrastructure decisions compound over time. That's the
          lens I bring to every project.
        </p>

        <!-- Education -->
        <div class="pt-6 border-t border-border">
          <h4 class="text-text-muted text-xs font-mono uppercase tracking-wider mb-3">Education</h4>
          <div class="flex items-baseline gap-3">
            <span class="text-text-primary font-medium">BSc Computer Science</span>
            <span class="text-text-muted text-sm">·</span>
            <span class="text-text-secondary text-sm">Universidade Católica de Pernambuco</span>
            <span class="text-text-muted text-sm font-mono">2016–2020</span>
          </div>
        </div>
      </div>

      <!-- Right: Publication + Certs -->
      <div class="space-y-6">

        <!-- Published Paper -->
        {publications.map((pub) => (
          <div class="card border-accent/20">
            <div class="flex items-center gap-2 mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent shrink-0">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
              <span class="text-xs font-mono text-accent uppercase tracking-wider">Published Research</span>
            </div>
            <p class="text-text-primary text-sm font-medium leading-snug mb-2">
              {pub.titleEn}
            </p>
            <p class="text-text-muted text-xs font-mono">{pub.venue} · {pub.year}</p>
          </div>
        ))}

        <!-- Certifications -->
        <div class="card">
          <h4 class="text-xs font-mono text-text-muted uppercase tracking-wider mb-4">Certifications</h4>
          <ul class="space-y-3">
            {certifications.map((cert) => (
              <li class="flex items-start gap-3">
                <span class="text-accent mt-1 shrink-0 text-xs">✓</span>
                <div>
                  <p class="text-text-secondary text-sm leading-tight">{cert.name}</p>
                  <p class="text-text-muted text-xs font-mono mt-0.5">{cert.issuer} · {cert.year}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </div>
</section>
